rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menú público: cualquiera puede leer; solo usuarios autenticados escriben.
    match /site/menu {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Deniega el resto por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
